    <div class="lb" id="lightbox" aria-hidden="true" role="dialog" aria-label="Screenshot viewer">
      <div class="lbPanel" role="document">
        <div class="lbTop">
          <div class="lbTitle" id="lbTitle">Screenshot</div>

          <div class="lbBtns">
            <div class="lbControls" aria-label="Zoom controls">
              <button class="lbBtn" type="button" id="lbZoomOut" aria-label="Zoom out">−</button>
              <input class="lbRange" id="lbZoom" type="range" min="1" max="4" value="1" step="0.05" aria-label="Zoom slider" />
              <button class="lbBtn" type="button" id="lbZoomIn" aria-label="Zoom in">+</button>
              <button class="lbBtn" type="button" id="lbReset" aria-label="Reset zoom">Reset</button>
            </div>

            <button class="lbBtn" type="button" id="lbClose" aria-label="Close viewer">Close</button>
          </div>
        </div>

        <div class="lbBody">
          <div class="lbStage" id="lbStage" aria-label="Zoom and pan area">
            <img class="lbImg" id="lbImg" alt="" />
          </div>
          <div class="lbHint">Wheel / pinch to zoom • Drag to pan • Esc to close</div>
        </div>
      </div>
    </div>

    <script>
      (function () {
        const APP_NAME = 'SmartAlertPlusTT';
        const tagline = 'Emergency alerts for the people you trust — fast, clear, and ready when it matters most.';

        const el1 = document.getElementById('appName');
        const el2 = document.getElementById('appName2');
        const elTag = document.getElementById('tagline');
        const elYear = document.getElementById('year');

        if (el1) el1.textContent = APP_NAME;
        if (el2) el2.textContent = APP_NAME;
        if (elTag) elTag.textContent = tagline;
        if (elYear) elYear.textContent = String(new Date().getFullYear());
      })();

      (function () {
        const carousels = document.querySelectorAll('[data-carousel]');

        carousels.forEach((root) => {
          const track = root.querySelector('[data-track]');
          const slides = Array.from(track.querySelectorAll('.slide'));
          const prev = root.querySelector('[data-prev]');
          const next = root.querySelector('[data-next]');
          const dotsWrap = root.querySelector('[data-dots]');

          if (!track || slides.length === 0 || !dotsWrap) return;

          const dots = slides.map((_, i) => {
            const b = document.createElement('button');
            b.className = 'dotBtn';
            b.type = 'button';
            b.setAttribute('aria-label', `Go to slide ${i + 1}`);
            b.addEventListener('click', () => scrollToIndex(i));
            dotsWrap.appendChild(b);
            return b;
          });

          function nearestIndex() {
            const center = track.scrollLeft + track.clientWidth / 2;
            let best = 0;
            let bestDist = Infinity;

            slides.forEach((s, i) => {
              const left = s.offsetLeft;
              const mid = left + s.clientWidth / 2;
              const d = Math.abs(mid - center);
              if (d < bestDist) {
                bestDist = d;
                best = i;
              }
            });

            return best;
          }

          function setActiveDot(i) {
            dots.forEach((d, idx) => {
              d.setAttribute('aria-current', idx === i ? 'true' : 'false');
            });
          }

          function scrollToIndex(i) {
            const s = slides[i];
            if (!s) return;
            const left = s.offsetLeft - (track.clientWidth - s.clientWidth) / 2;
            track.scrollTo({ left, behavior: 'smooth' });
            setActiveDot(i);
          }

          prev?.addEventListener('click', () => {
            const i = nearestIndex();
            scrollToIndex(Math.max(0, i - 1));
          });

          next?.addEventListener('click', () => {
            const i = nearestIndex();
            scrollToIndex(Math.min(slides.length - 1, i + 1));
          });

          let raf = 0;
          track.addEventListener('scroll', () => {
            cancelAnimationFrame(raf);
            raf = requestAnimationFrame(() => setActiveDot(nearestIndex()));
          });

          let isDown = false;
          let startX = 0;
          let startScroll = 0;

          track.addEventListener('pointerdown', (e) => {
            if (e.target && e.target.closest && e.target.closest('.slide img')) return;
            isDown = true;
            startX = e.clientX;
            startScroll = track.scrollLeft;
            track.setPointerCapture(e.pointerId);
          });

          track.addEventListener('pointermove', (e) => {
            if (!isDown) return;
            const dx = e.clientX - startX;
            track.scrollLeft = startScroll - dx;
          });

          track.addEventListener('pointerup', () => { isDown = false; });
          track.addEventListener('pointercancel', () => { isDown = false; });

          setActiveDot(0);
        });
      })();

      (function () {
        const lb = document.getElementById('lightbox');
        const lbImg = document.getElementById('lbImg');
        const lbTitle = document.getElementById('lbTitle');
        const lbStage = document.getElementById('lbStage');
        const btnClose = document.getElementById('lbClose');
        const btnIn = document.getElementById('lbZoomIn');
        const btnOut = document.getElementById('lbZoomOut');
        const btnReset = document.getElementById('lbReset');
        const range = document.getElementById('lbZoom');

        if (!lb || !lbImg || !lbTitle || !lbStage || !btnClose || !btnIn || !btnOut || !btnReset || !range) return;

        let scale = 1;
        let tx = 0;
        let ty = 0;
        let dragging = false;
        let startX = 0;
        let startY = 0;
        let startTx = 0;
        let startTy = 0;
        let pointers = new Map();
        let pinchStartDist = 0;
        let pinchStartScale = 1;

        function clamp(v, min, max) {
          return Math.max(min, Math.min(max, v));
        }

        function applyTransform() {
          lbImg.style.transform = `translate(${tx}px, ${ty}px) scale(${scale})`;
        }

        function openLightbox(src, alt) {
          lbImg.src = src;
          lbImg.alt = alt || 'Screenshot';
          lbTitle.textContent = alt || 'Screenshot';
          scale = 1;
          tx = 0;
          ty = 0;
          range.value = '1';
          applyTransform();
          lb.setAttribute('aria-hidden', 'false');
          document.body.style.overflow = 'hidden';
        }

        function closeLightbox() {
          lb.setAttribute('aria-hidden', 'true');
          document.body.style.overflow = '';
          lbImg.src = '';
        }

        function setScale(next, anchorX, anchorY) {
          const prev = scale;
          scale = clamp(next, 1, 4);
          range.value = String(scale);

          if (anchorX != null && anchorY != null && prev !== scale) {
            const rect = lbStage.getBoundingClientRect();
            const ax = anchorX - (rect.left + rect.width / 2);
            const ay = anchorY - (rect.top + rect.height / 2);
            const k = scale / prev - 1;
            tx -= ax * k;
            ty -= ay * k;
          }

          applyTransform();
        }

        lb.addEventListener('pointerdown', (e) => {
          if (e.target === lb) closeLightbox();
        });

        btnClose.addEventListener('click', closeLightbox);

        document.addEventListener('keydown', (e) => {
          if (lb.getAttribute('aria-hidden') === 'false' && e.key === 'Escape') closeLightbox();
        });

        btnIn.addEventListener('click', () => setScale(scale + 0.2));
        btnOut.addEventListener('click', () => setScale(scale - 0.2));
        btnReset.addEventListener('click', () => {
          scale = 1;
          tx = 0;
          ty = 0;
          range.value = '1';
          applyTransform();
        });

        range.addEventListener('input', () => {
          setScale(parseFloat(range.value || '1'));
        });

        lbStage.addEventListener('wheel', (e) => {
          if (lb.getAttribute('aria-hidden') !== 'false') return;
          e.preventDefault();
          const step = e.deltaY > 0 ? -0.12 : 0.12;
          setScale(scale + step, e.clientX, e.clientY);
        }, { passive: false });

        lbStage.addEventListener('pointerdown', (e) => {
          if (lb.getAttribute('aria-hidden') !== 'false') return;

          pointers.set(e.pointerId, { x: e.clientX, y: e.clientY });
          lbStage.setPointerCapture(e.pointerId);

          if (pointers.size === 1) {
            dragging = true;
            lbStage.classList.add('dragging');
            startX = e.clientX;
            startY = e.clientY;
            startTx = tx;
            startTy = ty;
          }

          if (pointers.size === 2) {
            const pts = Array.from(pointers.values());
            const dx = pts[0].x - pts[1].x;
            const dy = pts[0].y - pts[1].y;
            pinchStartDist = Math.hypot(dx, dy);
            pinchStartScale = scale;
            dragging = false;
            lbStage.classList.remove('dragging');
          }
        });

        lbStage.addEventListener('pointermove', (e) => {
          if (lb.getAttribute('aria-hidden') !== 'false') return;
          if (!pointers.has(e.pointerId)) return;

          pointers.set(e.pointerId, { x: e.clientX, y: e.clientY });

          if (pointers.size === 1 && dragging) {
            const dx = e.clientX - startX;
            const dy = e.clientY - startY;
            tx = startTx + dx;
            ty = startTy + dy;
            applyTransform();
          }

          if (pointers.size === 2) {
            const pts = Array.from(pointers.values());
            const dx = pts[0].x - pts[1].x;
            const dy = pts[0].y - pts[1].y;
            const dist = Math.hypot(dx, dy);

            if (pinchStartDist > 0) {
              const ratio = dist / pinchStartDist;
              const nextScale = pinchStartScale * ratio;
              const mx = (pts[0].x + pts[1].x) / 2;
              const my = (pts[0].y + pts[1].y) / 2;
              setScale(nextScale, mx, my);
            }
          }
        });

        function endPointer(e) {
          pointers.delete(e.pointerId);

          if (pointers.size === 0) {
            dragging = false;
            lbStage.classList.remove('dragging');
          }

          if (pointers.size === 1) {
            const only = Array.from(pointers.values())[0];
            startX = only.x;
            startY = only.y;
            startTx = tx;
            startTy = ty;
            dragging = true;
            lbStage.classList.add('dragging');
          }
        }

        lbStage.addEventListener('pointerup', endPointer);
        lbStage.addEventListener('pointercancel', endPointer);

        document.querySelectorAll('.slide img').forEach((img) => {
          img.addEventListener('click', (e) => {
            e.stopPropagation();
            openLightbox(img.getAttribute('src'), img.getAttribute('alt'));
          });
        });

        const hero = document.querySelector('.heroShot');
        hero?.addEventListener('click', (e) => {
          e.stopPropagation();
          openLightbox(hero.getAttribute('src'), hero.getAttribute('alt'));
        });
      })();

      (function () {
        const form = document.querySelector('#support form.msgForm');
        const success = document.getElementById('msgSuccess');

        if (!form || !success) return;

        form.addEventListener('submit', async function (e) {
          e.preventDefault();

          const btn = form.querySelector('button[type="submit"]');
          const originalText = btn ? btn.textContent : '';

          if (btn) {
            btn.disabled = true;
            btn.textContent = 'Sending...';
          }

          try {
            const res = await fetch(form.action, {
              method: 'POST',
              body: new FormData(form),
              headers: { Accept: 'application/json' }
            });

            if (!res.ok) throw new Error('Form submit failed');

            form.reset();
            form.style.display = 'none';
            success.style.display = 'block';
          } catch (err) {
            form.submit();
          } finally {
            if (btn) {
              btn.disabled = false;
              btn.textContent = originalText;
            }
          }
        });
      })();
    </script>
